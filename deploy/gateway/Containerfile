# ============================================
# API 网关容器
# 构建: podman build -f Containerfile -t taolib-gateway deploy/gateway/
# ============================================

FROM nginx:1.27-alpine

LABEL maintainer="xinetzone <735613050@qq.com>"
LABEL description="Taolib API 网关"

# 移除默认配置，使用自定义网关配置
RUN rm /etc/nginx/conf.d/default.conf

COPY nginx.conf /etc/nginx/conf.d/gateway.conf

EXPOSE 80

HEALTHCHECK --interval=15s --timeout=5s --retries=3 --start-period=5s \
    CMD wget -qO- http://localhost/health || exit 1

CMD ["nginx", "-g", "daemon off;"]
