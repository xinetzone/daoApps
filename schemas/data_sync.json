  "components": {
    "schemas": {
      "CreateJobRequest": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name",
            "description": "作业名称"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description",
            "description": "作业描述"
          },
          "scope": {
            "type": "string",
            "title": "Scope",
            "description": "同步范围"
          },
          "mode": {
            "type": "string",
            "title": "Mode",
            "description": "同步模式"
          },
          "source": {
            "additionalProperties": true,
            "type": "object",
            "title": "Source",
            "description": "源数据库配置"
          },
          "target": {
            "additionalProperties": true,
            "type": "object",
            "title": "Target",
            "description": "目标数据库配置"
          },
          "batch_size": {
            "type": "integer",
            "title": "Batch Size",
            "description": "批处理大小",
            "default": 100
          },
          "failure_action": {
            "type": "string",
            "title": "Failure Action",
            "description": "失败处理策略",
            "default": "skip"
          },
          "schedule_cron": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Schedule Cron",
            "description": "Cron 表达式"
          },
          "tags": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Tags",
            "description": "标签"
          }
        },
        "type": "object",
        "required": [
          "name",
          "scope",
          "mode",
          "source",
          "target"
        ],
        "title": "CreateJobRequest",
        "description": "创建作业请求。"
      },
      "FailureAction": {
        "type": "string",
        "enum": [
          "skip",
          "retry",
          "abort"
        ],
        "title": "FailureAction",
        "description": "失败处理动作。"
      },
      "FailureListResponse": {
        "properties": {
          "items": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Items"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          }
        },
        "type": "object",
        "required": [
          "items",
          "total"
        ],
        "title": "FailureListResponse",
        "description": "失败记录列表响应。"
      },
      "GlobalMetricsResponse": {
        "properties": {
          "total_jobs": {
            "type": "integer",
            "title": "Total Jobs"
          },
          "recent_runs": {
            "type": "integer",
            "title": "Recent Runs"
          },
          "completed": {
            "type": "integer",
            "title": "Completed"
          },
          "failed": {
            "type": "integer",
            "title": "Failed"
          }
        },
        "type": "object",
        "required": [
          "total_jobs",
          "recent_runs",
          "completed",
          "failed"
        ],
        "title": "GlobalMetricsResponse",
        "description": "全局指标响应。"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "database": {
            "type": "string",
            "title": "Database"
          }
        },
        "type": "object",
        "required": [
          "status",
          "database"
        ],
        "title": "HealthResponse",
        "description": "健康检查响应。"
      },
      "JobListResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/SyncJobResponse"
            },
            "type": "array",
            "title": "Items"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          }
        },
        "type": "object",
        "required": [
          "items",
          "total"
        ],
        "title": "JobListResponse",
        "description": "作业列表响应。"
      },
      "JobRunResponse": {
        "properties": {
          "log_id": {
            "type": "string",
            "title": "Log Id"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "log_id",
          "status",
          "message"
        ],
        "title": "JobRunResponse",
        "description": "作业运行响应。"
      },
      "LogListResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/SyncLogResponse"
            },
            "type": "array",
            "title": "Items"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          }
        },
        "type": "object",
        "required": [
          "items",
          "total"
        ],
        "title": "LogListResponse",
        "description": "日志列表响应。"
      },
      "SyncConnectionConfig": {
        "properties": {
          "mongo_url": {
            "type": "string",
            "title": "Mongo Url",
            "default": "mongodb://localhost:27017"
          },
          "database": {
            "type": "string",
            "title": "Database"
          },
          "collections": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Collections"
          }
        },
        "type": "object",
        "required": [
          "database"
        ],
        "title": "SyncConnectionConfig",
        "description": "数据库连接配置。"
      },
      "SyncJobResponse": {
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Name",
            "description": "作业名称（唯一）"
          },
          "description": {
            "type": "string",
            "maxLength": 1000,
            "title": "Description",
            "description": "作业描述",
            "default": ""
          },
          "scope": {
            "$ref": "#/components/schemas/SyncScope",
            "description": "同步范围",
            "default": "database"
          },
          "mode": {
            "$ref": "#/components/schemas/SyncMode",
            "description": "同步模式",
            "default": "incremental"
          },
          "source": {
            "$ref": "#/components/schemas/SyncConnectionConfig",
            "description": "源数据库连接"
          },
          "target": {
            "$ref": "#/components/schemas/SyncConnectionConfig",
            "description": "目标数据库连接"
          },
          "transform_module": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Transform Module",
            "description": "Python 转换函数模块路径"
          },
          "field_mapping": {
            "anyOf": [
              {
                "additionalProperties": {
                  "type": "string"
                },
                "type": "object"
