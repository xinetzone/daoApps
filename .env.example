# 道源项目环境变量配置

# 网站配置
TAOLIB_SITE_TITLE=道源
TAOLIB_SITE_SUBTITLE=道可道，非恒道
TAOLIB_SITE_DESCRIPTION=一个关于道、德、法、技、器的个人写作平台
TAOLIB_SITE_AUTHOR=xinetzone
TAOLIB_SITE_URL=http://localhost:8000
TAOLIB_SITE_DATABASE_URL=
TAOLIB_SITE_SECRET=
TAOLIB_SITE_ARTICLES_PER_PAGE=10
TAOLIB_SITE_COMMENTS_REQUIRE_APPROVAL=true
TAOLIB_SITE_ADMIN_USERNAME=admin
TAOLIB_SITE_ADMIN_PASSWORD=

# OAuth 配置
TAOLIB_OAUTH_JWT_SECRET=
TAOLIB_OAUTH_GITHUB_CLIENT_ID=
TAOLIB_OAUTH_GITHUB_CLIENT_SECRET=
TAOLIB_OAUTH_GOOGLE_CLIENT_ID=
TAOLIB_OAUTH_GOOGLE_CLIENT_SECRET=

# 邮件服务配置
TAOLIB_EMAIL_PROVIDER=
TAOLIB_EMAIL_API_KEY=
TAOLIB_EMAIL_FROM_ADDRESS=

# 文件存储配置
TAOLIB_FILE_STORAGE_PROVIDER=
TAOLIB_FILE_STORAGE_BUCKET=
TAOLIB_FILE_STORAGE_ACCESS_KEY=
TAOLIB_FILE_STORAGE_SECRET_KEY=

# 分析服务配置
TAOLIB_ANALYTICS_ENABLED=false

# 数据同步配置
TAOLIB_DATA_SYNC_ENABLED=false

# 速率限制配置
TAOLIB_RATE_LIMIT_ENABLED=true
TAOLIB_RATE_LIMIT_MAX_REQUESTS=100
TAOLIB_RATE_LIMIT_WINDOW_SECONDS=60

# 环境配置
TAOLIB_ENV=development
